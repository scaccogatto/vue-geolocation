{
  "name": "vue-browser-geolocation",
  "version": "3.0.0",
  "description": "Tiny, type-safe Geolocation for Vue 3 — a reactive useGeolocation() composable and standalone Promise-based helpers.",
  "author": {
    "name": "Marco Boffo",
    "email": "marcoboffo.waves@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaccogatto/vue-geolocation.git"
  },
  "bugs": {
    "url": "https://github.com/scaccogatto/vue-geolocation/issues"
  },
  "homepage": "https://github.com/scaccogatto/vue-geolocation#readme",
  "keywords": [
    "vue",
    "vue3",
    "geolocation",
    "composable",
    "typescript",
    "navigator",
    "coordinates"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "vue": "^3.2.25"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  },
  "engines": {
    "node": ">=20"
  }
}
